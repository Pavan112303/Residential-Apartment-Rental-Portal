# ────────────────────────────────────────────────────────────
#  Residential Apartment Rental Portal — Environment Template
#  Copy this file to .env and fill in your values.
# ────────────────────────────────────────────────────────────

# ─── Flask ───────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
FLASK_ENV=production

# ─── Database ────────────────────────────────────────────────
# Railway provides this automatically.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://user:password@localhost:5432/rental_portal

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here

# ─── CORS ────────────────────────────────────────────────────
# Set this to your Railway frontend URL in production.
# Example: https://your-frontend.up.railway.app
FRONTEND_URL=http://localhost:4200
